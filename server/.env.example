PORT=3001
JWT_SECRET=your_strong_jwt_secret_here
NODE_ENV=development

# ─── PostgreSQL Configuration ─────────────────────────────────────────────────
# Set these to activate PostgreSQL mode. Leave blank to fall back to SQLite.
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ai4care
DB_USER=postgres
DB_PASSWORD=your_db_password

# Optional: use a single connection string instead of host/port/name/user/password
# DATABASE_URL=postgres://user:password@host:port/dbname

# ─── AI / Gemini ──────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
